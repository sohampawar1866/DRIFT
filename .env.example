# --- CMEMS (Copernicus Marine) Credentials ---
# Get these from: https://marine.copernicus.eu/
COPERNICUSMARINE_SERVICE_USERNAME=your_username_here
COPERNICUSMARINE_SERVICE_PASSWORD=your_password_here

# --- ERA5 (ECMWF CDS) Credentials ---
# Get these from: https://cds.climate.copernicus.eu/how-to-api
# Format is UID:API-KEY (e.g., 12345:abc-def-ghi)
CDSAPI_KEY=your_uid:your_api_key_here
CDSAPI_URL=https://cds.climate.copernicus.eu/api/v2

# --- AWS Access (Sentinel-2 Public Dataset) ---
# Note: Sentinel-2 data on AWS Earth Search is public; no AWS API keys required.
# If you need to hit private buckets, add AWS_ACCESS_KEY_ID/SECRET here.
AWS_REGION=us-east-1
